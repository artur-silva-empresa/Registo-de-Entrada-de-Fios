{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": "dist-server/server.cjs",
  "main": "dist-server/electron-main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && npm run build:server && npm run build:electron",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist-server/server.cjs --external:better-sqlite3 --external:vite",
    "build:electron": "esbuild electron-main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist-server/electron-main.cjs --external:electron",
    "build:exe": "npm run build && npm run build:server && npm run pkg",
    "electron:dev": "npm run build:server && npm run build:electron && electron dist-server/electron-main.cjs",
    "electron:build": "npm run build && npm run build:server && npm run build:electron && electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "pkg": "pkg . --targets node24-win-x64 --output GestaoFios.exe",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server GestaoFios.exe",
    "lint": "tsc --noEmit",
    "start": "node dist-server/server.cjs"
  },
  "engines": {
    "node": "24.14.1"
  },
  "build": {
    "appId": "com.gestaofios.app",
    "productName": "GestaoFios",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "portable"
    }
  },
  "pkg": {
    "assets": [
      "dist/**"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^24.14.1",
    "autoprefixer": "^10.4.21",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.27.4",
    "pkg": "^5.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
